if [[ "$1" =~ ^- ]]; then
  case $1 in
  -s)
  # ńįŇülemlere baŇülamadan √∂nce /tmp/ses i√ßi temizlik
  [[ "$(du -s '/tmp/ses/ff'|head -n1|cut -f1)" != 0 ]] && \
  find '/tmp/ses' -type f \( -iname "*.mp3" -o -iname "*.mp4" \) -exec rm -rf {} \;
  # Dublaj Ses dosyasńĪ oluŇüturma komut blok
  trap TEMiZLE EXIT
  g2="`pwd`/$2"
  g4="`pwd`/$4"
  set -- "$1" "`dirname "$g2"`/`basename "$g2"`" "$3" "`dirname "$g4"`/`basename "$g4"`"
  # AltyazńĪ varlńĪńüńĪ kontrol
  if ! test "${2/*./}" == "srt"; then
   play -q -n -c1 synth sin %-12 sin %-9 sin %-5 sin %-2 fade q 0.1 1 0.1
   echo -e "Desteklenmeyen altyazńĪ dosya...\nńįŇülem sonlandńĪrńĪlńĪp √ßńĪkńĪŇü yapńĪlńĪyor..."
   TEMiZLE 2>/dev/null
   exit 0
  fi

  # AltyazńĪ bi√ßimlendirme d√ľzenleme
  read -r TAM < <(echo "`grep -c "[0-9][0-9]:[0-9][0-9]:" "$2"` 2 * n"|dc)
  paste -- \
  <(grep -now "^[0-9][0-9]:[0-9][0-9]:[0-9][0-9]" "$2"|sed '$d') \
  <(grep -now "^[0-9][0-9]:[0-9][0-9]:[0-9][0-9]" "$2"|sed '1d')|\
  awk -F: '{print $2":"$3":"$4,$1}' >'/tmp/ses/Z_M.log'
  grep -now "^[0-9][0-9]:[0-9][0-9]:[0-9][0-9]" "$2"|tail -n1|\
  awk -F: -v s="$(wc -l <"$2")" '{print $2":"$3":"$4"\t"s+1,$1}' >>'/tmp/ses/Z_M.log'
  strings '/tmp/ses/Z_M.log'|while read -r oku; do
    _oku=( $oku )
    MT="`sed -n -e 's/<[^>]*>//g' -e ''"$((_oku[2]+1)),$((_oku[1]-2))"'p' "$2"|tr [:space:] ' '`"
    printf "%s_%s\n" "${_oku[0]}" "$MT" >>'/tmp/ses/sub.log'
    echo -ne "\r`wc -l <'/tmp/ses/sub.log'` > $TAM"
  done
  cut -d_ -f1 '/tmp/ses/sub.log'|strings|uniq|while read -r oku; do
    SN="$(awk -F: '{print $1*60*60+$2*60+$3}' <<<"$oku")"
    AL="$(awk -F_ '/^'"$oku"'/{printf "%s ",$2}' '/tmp/ses/sub.log'\
    |sed -e 's/[[][^[]*]//g' -e 's/([^)]*)//g' -e 's/\W/ /g' -e 's/\s\{1,\}/ /g' -e 's/^\s//')"
    [[ "$AL" =~ ([A-Za-z]) ]] && \
    printf "%s#%s#%s\n" "${SN}" "${oku}" "${AL}" >>'/tmp/ses/srt.log'
    read -r EK< <(wc -l <'/tmp/ses/srt.log'|awk -v x="`grep -c "[0-9][0-9]:[0-9][0-9]:" "$2"`" '{print $1+x}')
    echo -ne "\r${EK} > ${TAM}"
  done

  # Elde edilen altyazńĪ metin dosyasńĪ ile dińüer girdiler dolar deńüerine atanńĪr.
  rm '/tmp/ses/Z_M.log'
  VX=( "/tmp/ses/srt.log" "${3/-*/}" "${3/*-/}" "$4" )
  echo -ne "\r\n"
  echo -e "${m_r}${y_K}ŗľļ  ${y_X}${r_X} ${m_i}${y_K}‚üÜŌÖŠĎ≤‚üÜ‚ąą‚üÜ${r_X}${y_X} ${m_r}${y_K}ŗľĽ ${r_X}${y_X}\nViD: ${4/*\//}\nSUB: ${2/*\//}\nDiL: ${3/-*/}"

  i=0
  aa=0
  D=01234567
  bb="$(grep -c '[0-9][0-9]:[0-9]' "${VX[0]}")"
  while read -r oku; do
   SN="$(cut -d# -f1 <<<"$oku")"
   YZ="$(cut -d# -f3 <<<"$oku")"
   wget -q -U Mozilla -O "/tmp/ses/${SN}.mp3" \
   "https://translate.google.com/translate_tts?ie=UTF-8&tl=${VX[1]}&client=tw-ob&q=${YZ,,}" &&\
   ((aa++)) || true
   Y=$(("${aa}*100/${bb}*100"/100))
   B=$(("${Y}*5"/10))
   K=$((50-B))
   T=$(perl -E 'say "‚ĒÉ"x'"$B")
   E=$(perl -E 'say "‚ēļ"x'"$K")
   # shellcheck disable=SC2027
   j="\e[1;3"${D:i++%${#D}:1}"m"
   echo -ne "\r${y_K}`du -hs '/tmp/ses'|cut -f1`${y_X}${j}\
   ‚ēŹ${r_X}${k_i}${T}${r_X}${m_r}${y_K}${E}${y_X}${r_X}${j}‚ēŹ${r_X}\e[21;34m${y_K} ${Y}%${y_X}${r_X}"
  done <'/tmp/ses/srt.log'

  # ńįlk baŇülangńĪ√ß boŇüluk ses oluŇüturulur birleŇütirmek i√ßin log aktarńĪlńĪr.
  sox -n -r 44100 '/tmp/ses/ff/0.mp3' trim 0.0 "$(head -n1 "${VX[0]}"|cut -d# -f1)".000
  echo "file '/tmp/ses/ff/0.mp3' " >"/tmp/ses/ff/bir.log"
  perl -e 'open SX, "cut -d# -f2 '"${VX[0]}"'|" or die $_=qx(notify-send --icon=info "SRT OKUNAMADI");
  my @x1;
  my $i = 1;
  while(<SX>){
    my ($x1, $x2, $x3, $x4, $x5) = split/(:|,)/;
    unshift(@x1, $x1*60*60+$x3*60+$x5);
    if (defined @x1[1]){
     $x2 = pop @x1;
     $x4 = @x1[0]-$x2;
     print $x4,"\t",$x2,".mp3\t$i\n";
     $i += 1;
    }
  } print @x1,".mp3\t$i";' > "/tmp/ses/XX.log"
  bb="$(grep -c 'mp3' <'/tmp/ses/XX.log')"
  strings "/tmp/ses/XX.log"|while read -ra oku; do
   # Ses dosyalarńĪn d√ľzenleme ve birleŇütirme
   if [[ "${#oku[@]}" -eq 3 ]]; then
    # Ses dosyasńĪ hńĪzlandńĪrńĪlńĪr. ff klosere aktarńĪlńĪr.
    sox -q "/tmp/ses/${oku[1]}" '/tmp/ses/X.mp3' tempo "${VX[2]}" rate 44100 || exit 2
    # Ses zamanńĪ alńĪnńĪr. Ara boŇüluk oluŇüturulur.
    SES=$(soxi '/tmp/ses/X.mp3'|awk -F':|\\.' '/Duration/{printf "%d",$3*60+$4+0}')
    sox -q -n -r 44100 '/tmp/ses/x.mp3' trim 0.0 "${oku[0]}".000 || exit 2

    # Mevcut ses ile ara boŇüluńüun uyumluluk kontrol edilir.
    # Deńüilse ses uyumlu hale gelecek Ňüekilde kesilir.
    if [[ "$SES" -le "${oku[0]}" ]]; then
     # Ses ile boŇüluk birleŇütirilir.
     sox -q -M '/tmp/ses/x.mp3' '/tmp/ses/X.mp3' "/tmp/ses/ff/${oku[2]}.mp3"
    else
     sox -q -M '/tmp/ses/x.mp3' '/tmp/ses/X.mp3' "/tmp/ses/ff/${oku[2]}.mp3" trim 0 "${oku[0]}"
     TM="`printf '%02d:%02d:%02d' \
     "$((${oku[1]/.*/}/3600%24))" "$((${oku[1]/.*/}/60%60))" "$((${oku[1]/.*/}%60))"`"
     awk -F_ '/^'"$TM"'/{print $1"\n"$2"\n\n"}' '/tmp/ses/sub.log' >>'/tmp/ses/A.log'
    fi
    # ńįŇülem sonunda oluŇüturulan fazlalńĪk sesler silinir.
    rm -rf "/tmp/ses/x.mp3" "/tmp/ses/X.mp3" 2>/dev/null

    # iŇülem sonunda hazńĪrlanan ses log aktarńĪlarak log dosyasńĪna birleŇütirmek i√ßin yazdńĪrńĪlńĪr.
    echo "file '/tmp/ses/ff/${oku[2]}.mp3' " >>"/tmp/ses/ff/bir.log"
    Y=$(("$((oku[2]+1))*100/${bb}*100"/100))
    B=$(("${Y}*5"/10))
    K=$((50-B))
    T=$(perl -E 'say "‚ĒÉ"x'"$B")
    E=$(perl -E 'say "‚ēļ"x'"$K")
    # shellcheck disable=SC2027
    j="\e[1;3"${D:i++%${#D}:1}"m"
    echo -ne "\r${y_K}`du -hs '/tmp/ses/ff'|cut -f1`${y_X}${j}\
    ‚ēŹ${r_X}${k_i}${T}${r_X}${m_r}${y_K}${E}${y_X}${r_X}${j}‚ēŹ${r_X}\e[21;34m${y_K} ${Y}%${y_X}${r_X}"
   elif [[ "${#oku[@]}" -eq 2 ]]; then
    sox -q "/tmp/ses/${oku[0]}" "/tmp/ses/ff/${oku[1]}.mp3" tempo "${VX[2]}"
    echo "file '/tmp/ses/ff/${oku[1]}.mp3' " >>"/tmp/ses/ff/bir.log"
    echo
    ffmpeg -nostdin -loglevel quiet \
    -f concat -safe 0 -i "/tmp/ses/ff/bir.log" -c:a copy "${VX[3]/.*/}.mp3"

    # Ses dosyalarńĪn log dosyasńĪnńĪ kontrol ve birleŇütirme veya sadeceses dosyasńĪnńĪ alma
    if test -e '/tmp/ses/ff/bir.log'; then
     yad --title="ūĚēäūĚēĆūĚĒĻūĚēäūĚĒľūĚēä" --window-icon="$HOME/.config/subses/subses.png" \
         --height=100 --width=300 --text "Video Ses birleŇütirme yapńĪlsńĪn mńĪ?" \
         --button="Dublajla":1 --button="√áIKIŇě":2
     bk=$?
     case $bk in
      1)
      [[ -e '/tmp/ses/A.log' ]] && {
      echo -ne "\rńįŇülem iptal: ${k_i}${y_K}Cancel${y_X}${r_X}\t\tDevam et: ${m_i}${y_K}OK${y_X}${r_X}";
      echo ;
      }
      [[ -e '/tmp/ses/A.log' ]] && {
      yad --text-info --title="HATA TOPLAM :   $(grep -c "[0-9][0-9]:" '/tmp/ses/A.log')" \
          --window-icon="$HOME/.config/subses/subses.png" \
          --height=400 --width=700 --wrap --justify=center< <(fmt -sw 80 '/tmp/ses/A.log')
      [ $? = 0 ] || { TEMiZLE 2>/dev/null; exit 2 ; }
      }
      (
      ffmpeg -i "${VX[3]}" -an '/tmp/ses/z.mp4' 2>&1|tee '/tmp/ses/f1.txt'
      ) >/dev/null &
      ff=$!
      while ps "$ff" >/dev/null; do
       echo -ne "\r$(strings '/tmp/ses/f1.txt'|grep "^frame"|tail -n1|grep -o "size.*speed....")"
       sleep 0.5
       if [[ "$(strings '/tmp/ses/f1.txt'|tail -n1)" =~ "Error" ]]; then
        echo -ne "\r$(strings '/tmp/ses/f1.txt'|tail -n1)";
       fi
      done
      (
      ffmpeg -i '/tmp/ses/z.mp4' -i "${VX[3]/.*/}.mp3" -c copy "${VX[3]/.*/}.${VX[1]}.mkv" 2>&1|tee '/tmp/ses/f1.txt'
      ) >/dev/null &
      ff=$!
      while ps "$ff" >/dev/null; do
       echo -ne "\r$(strings '/tmp/ses/f1.txt'|grep "^frame"|tail -n1|grep -o "size.*speed....")"
       sleep 0.5
       if [[ "$(strings '/tmp/ses/f1.txt'|tail -n1)" =~ "Error" ]]; then
        echo -ne "\r$(strings '/tmp/ses/f1.txt'|tail -n1)";
       fi
      done
      echo -ne "\r\n"
      echo -ne "\r${m_i}${y_K}TAMAMLANDI:${y_x}${r_X} '${VX[3]/.*/}.${VX[1]}.mkv'"
      ;;
      2)
      echo -ne "\r${m_i}${y_K}TAMAMLANDI:${y_x}${r_X} '${VX[3]/.*/}.${VX[1]}.mp3'"
      ;;
     esac
    fi
   fi
  done
  rm -rf '/tmp/ses/ff/bir.log' '/tmp/ses/f1.txt' '/tmp/ses/A.log' '/tmp/ses/XX.log' '/tmp/ses/srt.log' '/tmp/ses/sub.log' 2>/dev/null
  ;;
  -m)
  cop() {
  find '/tmp/ses/X' -type f \( \
                  -iname "*.txt" \
                  -o -iname "*.mp3" \
                  -o -iname "*.log" \) -exec rm -rf {} \;
  }
  # X kloser kontrol varsa i√ßi boŇüaltńĪlńĪr, yoksa oluŇüturulur.
  if test -d '/tmp/ses/X'; then cop; else mkdir -p '/tmp/ses/X'; fi
  # Xterm √ßalńĪŇütńĪrńĪlńĪr bilgi vermek i√ßin
  if test -z "$4"; then
   echo "ńįŇülem baŇülatńĪlńĪyor..." >'/tmp/ses/X/xterm.log'
   xterm -geometry 80x10-10+350 -fa -hold -T 'ūĚēäūĚēĆūĚĒĻūĚēäūĚĒľūĚēä' -e 'bash -c "watch -n1 cat /tmp/ses/X/xterm.log"' &
   XM=$!
