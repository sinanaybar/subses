#!/usr/bin/env bash

## SUBSES çalışken farklı bir işlem başlatmayın, srt biçimlerine dikkat edin.
## SRT aralıkların 1 sn'den az veya aynı zaman olursa altyazılar birleştirilip okunacak.
## Altyazı karekter sayısı ile zaman aralığı uygun olmalıdır, yoksa sesler kesilecektir.
## Gerekli şartlar karşılandığında Manjaro xfce4 da sorunsuz çalışmaktadır.
## Diğer dağıtımlarda deneme yapmadığım için düzenleme yapmak gerekli olabilir.
## https://github.com/sinanaybar/subses
## sinanaybar@yandex.com
## https://www.youtube.com/watch?v=MJqDyuQW59E
## YÜKLÜ OLDUĞUNDAN EMİN OLUN: Yardımcı uygulamarın kurulu değilse kurun.
## ffmpeg _ mpv _ yad _ xclip _ sox _ xterm _ xev _ tesseract

SUBSES="
--------------------------------------
██████████████████████████████████████
█─▄▄▄▄█▄─██─▄█▄─▄─▀█─▄▄▄▄█▄─▄▄─█─▄▄▄▄█
█▄▄▄▄─██─██─███─▄─▀█▄▄▄▄─██─▄█▀█▄▄▄▄─█
▀▄▄▄▄▄▀▀▄▄▄▄▀▀▄▄▄▄▀▀▄▄▄▄▄▀▄▄▄▄▄▀▄▄▄▄▄▀
--------------------------------------
"
# Yazdırma işlemi özelleştirmek için değerler atıyoruz.
y_K="$(tput bold)"
y_X="$(tput sgr0)"
k_i='\e[1;31m'
y_l="\e[1;32m"
s_i="\e[1;33m"
m_i='\e[1;34m'
m_r='\e[1;35m'
r_X="\e[0m"
[[ ! -d "/tmp/ses/ff" ]] && mkdir -p "/tmp/ses/ff"

# Gerekli yardımcı uyg kontrol işlemi.
test -f "$HOME/.config/subses/subses.png" || {
yad --dnd --title="𝕊𝕌𝔹𝕊𝔼𝕊" \
     --window-icon="$HOME/.config/subses/subses.png" \
     --height=100 --width=300 \
     --text="Gerekli Dosyalar konumda değil...\n$HOME/.config/subses/subses.png";
}
test -f "$HOME/.config/subses/dil.log" || {
yad --dnd --title="𝕊𝕌𝔹𝕊𝔼𝕊" \
     --window-icon="$HOME/.config/subses/subses.png" \
     --height=100 --width=300 \
     --text="Gerekli Dosyalar konumda değil...\n$HOME/.config/subses/dil.log";
}
which subses >/dev/null || {
yad --dnd --title="𝕊𝕌𝔹𝕊𝔼𝕊" \
    --window-icon="$HOME/.config/subses/subses.png" \
    --height=100 --width=300 \
    --text="Subses uyg çalıştırılabilir konumda değil..!";
}
which yt-dlp >/dev/null || {
yad --dnd --title="𝕊𝕌𝔹𝕊𝔼𝕊" \
    --window-icon="$HOME/.config/subses/subses.png" \
    --height=100 --width=300 \
    --text="YT-DLP uyg yüklü değil...";
}
which wget >/dev/null || {
yad --dnd --title="𝕊𝕌𝔹𝕊𝔼𝕊" \
    --window-icon="$HOME/.config/subses/subses.png" \
    --height=100 --width=300 \
    --text="WGET uyg yüklü değil...";
}
which sox >/dev/null || {
yad --dnd --title="𝕊𝕌𝔹𝕊𝔼𝕊" \
    --window-icon="$HOME/.config/subses/subses.png" \
    --height=100 --width=300 \
    --text="SOX uyg yüklü değil...";
}
which ffmpeg >/dev/null || {
yad --dnd --title="𝕊𝕌𝔹𝕊𝔼𝕊" \
    --window-icon="$HOME/.config/subses/subses.png" \
    --height=100 --width=300 \
    --text="FFMPEG uyg yüklü değil...";
}
which tesseract >/dev/null || {
yad --dnd --title="𝕊𝕌𝔹𝕊𝔼𝕊" \
    --window-icon="$HOME/.config/subses/subses.png" \
    --height=100 --width=300 \
    --text="TESSERACT uyg yüklü değil...";
}
which mpv >/dev/null || {
yad --dnd --title="𝕊𝕌𝔹𝕊𝔼𝕊" \
    --window-icon="$HOME/.config/subses/subses.png" \
    --height=100 --width=300 \
    --text="MPV uyg yüklü değil...";
}
which xterm >/dev/null || {
yad --dnd --title="𝕊𝕌𝔹𝕊𝔼𝕊" \
    --window-icon="$HOME/.config/subses/subses.png" \
    --height=100 --width=300 \
    --text="XTERM uyg yüklü değil...";
}
which xev >/dev/null || {
yad --dnd --title="𝕊𝕌𝔹𝕊𝔼𝕊" \
    --window-icon="$HOME/.config/subses/subses.png" \
    --height=100 --width=300 \
    --text="XEV uyg yüklü değil...";
}
# Ses dosya oluşturma yapıldığı için, çoklu çalışmalar da çakışmaya neden olabilir.
if [[ "$(ps axu|awk '{if($11=="bash" && $12=="subses") print $2| "wc -l"}')" -ge 3 ]]; then
yad --title="⟆υᑲ⟆∈⟆" \
    --height=100 --width=500 \
    --window-icon="$HOME/.config/subses/subses.png" \
    --text "SUBSES uyg aynı anda çoklu olarak kullanmak hataya neden olabilir..!
Lütfen mevcut bir işleminiz varsa bitmesini bekleyin.

Devam etmek istiyor musunuz ?" \
    --button=HAYIR:1 --button=EVET:0 --buttons-layout=center
[ $? = 0 ] || exit 0
fi
# UYG komut ana gövde
if [[ "$1" =~ ^- ]]; then
  case $1 in
  -s)
  # İşlemlere başlamadan önce /tmp/ses içi temizlik
  TEMiZLE() {
  find '/tmp/ses' -type f \( \
                  -iname "*.mp3" \
                  -o -iname "*.mp4" \
                  -o -iname "Z_M.log" \
                  -o -iname "sub.log" \
                  -o -iname "srt.log" \
                  -o -iname "bir.log" \
                  -o -iname "Z_M.log" \
                  -o -iname "A.log" \
                  -o -iname "f1.txt" \) -exec rm -rf {} \;
  }
  [[ "$(du -s '/tmp/ses/ff'|head -n1|cut -f1)" != 0 ]] && TEMiZLE 2>/dev/null
  g2="`pwd`/$2"
  g4="`pwd`/$4"
  set -- "$1" "`dirname "$g2"`/`basename "$g2"`" "$3" "`dirname "$g4"`/`basename "$g4"`"
  # Altyazı varlığı kontrol
  [[ "${2/.*/}" =~ "#" ]] && {
  echo -e "${k_i}${y_K}Altyazı adından '#' kaldırın..! ${y_X}${r_X}\n${2/.*/}";
  exit 2 ;
  }
  [[ "${2/*./}" =~ "srt" ]] || {
  echo -e "Desteklenmeyen altyazı dosya...\nİşlem sonlandırılıp çıkış yapılıyor...";
  TEMiZLE 2>/dev/null ;
  exit 0 ;
  }
  trap TEMiZLE EXIT
  # Altyazı biçimlendirme düzenleme
  read -r TAM < <(echo "`grep -c "[0-9][0-9]:[0-9][0-9]:" "$2"` 2 * n"|dc)
  paste -- \
  <(grep -now "^[0-9][0-9]:[0-9][0-9]:[0-9][0-9]" "$2"|sed '$d') \
  <(grep -now "^[0-9][0-9]:[0-9][0-9]:[0-9][0-9]" "$2"|sed '1d')|\
  awk -F: '{print $2":"$3":"$4,$1}' >'/tmp/ses/Z_M.log'
  grep -now "^[0-9][0-9]:[0-9][0-9]:[0-9][0-9]" "$2"|tail -n1|\
  awk -F: -v s="$(wc -l <"$2")" '{print $2":"$3":"$4"\t"s+1,$1}' >>'/tmp/ses/Z_M.log'
  strings '/tmp/ses/Z_M.log'|while read -r oku; do
    _oku=( $oku )
    MT="`sed -n -e 's/<[^>]*>//g' -e ''"$((_oku[2]+1)),$((_oku[1]-2))"'p' "$2"|tr [:space:] ' '`"
    printf "%s#%s\n" "${_oku[0]}" "$MT" >>'/tmp/ses/sub.log'
    echo -ne "\r`wc -l <'/tmp/ses/sub.log'` > $TAM"
  done
  cut -d# -f1 '/tmp/ses/sub.log'|strings|uniq|while read -r oku; do
    SN="$(awk -F: '{print $1*60*60+$2*60+$3}' <<<"$oku")"
    AL="$(awk -F# '/^'"$oku"'/{printf "%s ",$2}' '/tmp/ses/sub.log'\
    |sed -e 's/[[][^[]*]//g' -e 's/([^)]*)//g' -e 's/\W/ /g' -e 's/\s\{1,\}/ /g' -e 's/^\s//')"
    [[ "$AL" =~ ([A-Za-z]) ]] && printf "%s#%s#%s\n" "${SN}" "${oku}" "${AL}" >>'/tmp/ses/srt.log'
    read -r EK< <(wc -l <'/tmp/ses/srt.log'|awk -v x="`grep -c "[0-9][0-9]:[0-9][0-9]:" "$2"`" '{print $1+x}')
    echo -ne "\r${EK} > ${TAM}"
  done

  # Elde edilen altyazı metin dosyası ile diğer girdiler dolar değerine atanır.
  VX=( "/tmp/ses/srt.log" "${3/-*/}" "${3/*-/}" "$4" )
  echo -ne "\r\n"
  echo -e "${m_r}${y_K}༺  ${y_X}${r_X} ${m_i}${y_K}⟆υᑲ⟆∈⟆${r_X}${y_X} ${m_r}${y_K}༻ ${r_X}${y_X}\nViD: ${4/*\//}\nSUB: ${2/*\//}\nDiL: ${3/-*/}"

  i=0
  aa=0
  D=01234567
  bb="$(grep -c '[0-9][0-9]:[0-9]' "${VX[0]}")"
  while read -r oku; do
   SN="$(cut -d# -f1 <<<"$oku")"
   YZ="$(cut -d# -f3 <<<"$oku")"
   wget -q -U Mozilla -O "/tmp/ses/${SN}.mp3" \
   "https://translate.google.com/translate_tts?ie=UTF-8&tl=${VX[1]}&client=tw-ob&q=${YZ,,}" &&\
   ((aa++)) || true
   Y=$(("${aa}*100/${bb}*100"/100))
   B=$(("${Y}*5"/10))
   K=$((50-B))
   T=$(perl -E 'say "┃"x'"$B")
   E=$(perl -E 'say "╺"x'"$K")
   # shellcheck disable=SC2027
   j="\e[1;3"${D:i++%${#D}:1}"m"
   echo -ne "\r${y_K}`du -hs '/tmp/ses'|cut -f1`${y_X}${j}\
   ╏${r_X}${k_i}${T}${r_X}${m_r}${y_K}${E}${y_X}${r_X}${j}╏${r_X}\e[21;34m${y_K} ${Y}%${y_X}${r_X}"
  done <'/tmp/ses/srt.log'

  # İlk başlangıç boşluk ses oluşturulur birleştirmek için log aktarılır.
  if (( "$(head -n1 "${VX[0]}"|cut -d# -f1)" >= 1 )); then
   sox -n -r 44100 '/tmp/ses/ff/0.mp3' trim 0.0 "$(head -n1 "${VX[0]}"|cut -d# -f1)".000
   echo "file '/tmp/ses/ff/0.mp3' " >"/tmp/ses/ff/bir.log"
  else
   echo -ne >"/tmp/ses/ff/bir.log"
  fi
  perl -e 'open SX, "cut -d# -f2 '"${VX[0]}"'|" or die $_=qx(notify-send --icon=info "SRT OKUNAMADI");
  my @x1;
  my $i = 1;
  while(<SX>){
    my ($x1, $x2, $x3, $x4, $x5) = split/(:|,)/;
    unshift(@x1, $x1*60*60+$x3*60+$x5);
    if (defined @x1[1]){
     $x2 = pop @x1;
     $x4 = @x1[0]-$x2;
     print $x4,"\t",$x2,".mp3\t$i\n";
     $i += 1;
    }
  } print @x1,".mp3\t$i";' > '/tmp/ses/Z_M.log'
  bb="$(grep -c 'mp3' <'/tmp/ses/Z_M.log')"
  strings '/tmp/ses/Z_M.log'|while read -ra oku; do
   # Ses dosyaların düzenleme ve birleştirme
   if [[ "${#oku[@]}" == 3 ]]; then
    # Ses dosyası hızlandırılır. ff klosere aktarılır.
    sox -q "/tmp/ses/${oku[1]}" '/tmp/ses/X.mp3' tempo "${VX[2]}" rate 44100
    # Ses zamanı alınır. Ara boşluk oluşturulur.
    SES="$(soxi '/tmp/ses/X.mp3'|awk -F':|\\.' '/Duration/{print $4+0}')"
    sox -q -n -r 44100 '/tmp/ses/x.mp3' trim 0.0 "${oku[0]}".000

    # Mevcut ses ile ara boşluğun uyumluluk kontrol edilir.
    # Değilse ses uyumlu hale gelecek şekilde kesilir.
    if [[ "${SES}" < "${oku[0]}" ]]; then
     # Ses ile boşluk birleştirilir.
     sox -q -M '/tmp/ses/x.mp3' '/tmp/ses/X.mp3' "/tmp/ses/ff/${oku[2]}.mp3"
    else
     sox -q '/tmp/ses/X.mp3' '/tmp/ses/X.mp3' trim 0 "${oku[0]}".00 2>/dev/null
     sox -q -M '/tmp/ses/x.mp3' '/tmp/ses/X.mp3' "/tmp/ses/ff/${oku[2]}.mp3"
     TM="`printf '%02d:%02d:%02d' \
     "$((${oku[1]/.*/}/3600%24))" "$((${oku[1]/.*/}/60%60))" "$((${oku[1]/.*/}%60))"`"
     awk -F# '/^'"$TM"'/{print $1"\n"$2"\n\n"}' '/tmp/ses/sub.log' >>'/tmp/ses/A.log'
    fi
    # İşlem sonunda oluşturulan fazlalık sesler silinir.
    rm -rf "/tmp/ses/x.mp3" "/tmp/ses/X.mp3" 2>/dev/null

    # işlem sonunda hazırlanan ses log aktarılarak log dosyasına birleştirmek için yazdırılır.
    echo "file '/tmp/ses/ff/${oku[2]}.mp3' " >>"/tmp/ses/ff/bir.log"
    Y=$(("$((oku[2]+1))*100/${bb}*100"/100))
    B=$(("${Y}*5"/10))
    K=$((50-B))
    T=$(perl -E 'say "┃"x'"$B")
    E=$(perl -E 'say "╺"x'"$K")
    # shellcheck disable=SC2027
    j="\e[1;3"${D:i++%${#D}:1}"m"
    echo -ne "\r${y_K}`du -hs '/tmp/ses/ff'|cut -f1`${y_X}${j}\
    ╏${r_X}${k_i}${T}${r_X}${m_r}${y_K}${E}${y_X}${r_X}${j}╏${r_X}\e[21;34m${y_K} ${Y}%${y_X}${r_X}"
   else
    sox -q "/tmp/ses/${oku[0]}" "/tmp/ses/ff/${oku[1]}.mp3" tempo "${VX[2]}"
    echo "file '/tmp/ses/ff/${oku[1]}.mp3' " >>"/tmp/ses/ff/bir.log"
    echo
    ffmpeg -nostdin -loglevel quiet \
    -f concat -safe 0 -i "/tmp/ses/ff/bir.log" -c:a copy "${VX[3]/.*/}.mp3"

    # Ses dosyaların log dosyasını kontrol ve birleştirme veya sadeceses dosyasını alma
    if test -e '/tmp/ses/ff/bir.log'; then
     yad --title="𝕊𝕌𝔹𝕊𝔼𝕊" --window-icon="$HOME/.config/subses/subses.png" \
         --height=100 --width=300 --text "Video Ses birleştirme yapılsın mı?" \
         --button="Dublajla":1 --button="ÇIKIŞ":2
     bk=$?
     case $bk in
      1)
      test -f '/tmp/ses/A.log' && {
      echo -ne "\rİşlem iptal: ${k_i}${y_K}Cancel${y_X}${r_X}\t\tDevam et: ${m_i}${y_K}OK${y_X}${r_X}";
      echo ;
      }
      test -f '/tmp/ses/A.log' && {
      yad --text-info --title="HATA TOPLAM :   $(grep -c "[0-9][0-9]:" '/tmp/ses/A.log')" \
          --window-icon="$HOME/.config/subses/subses.png" \
          --height=400 --width=700 --wrap --justify=center< <(fmt -sw 80 '/tmp/ses/A.log')
      [ $? = 0 ] || { TEMiZLE 2>/dev/null; exit 2 ; }
      }
      (
      ffmpeg -i "${VX[3]}" -an '/tmp/ses/z.mp4' 2>&1|tee '/tmp/ses/f1.txt'
      ) >/dev/null &
      ff=$!
      while ps "$ff" >/dev/null; do
       echo -ne "\r$(strings '/tmp/ses/f1.txt'|grep "^frame"|tail -n1|grep -o "size.*speed....")"
       sleep 0.5
       if [[ "$(strings '/tmp/ses/f1.txt'|tail -n1)" =~ "Error" ]]; then
        echo -ne "\r$(strings '/tmp/ses/f1.txt'|tail -n1)";
       fi
      done
      (
      ffmpeg -i '/tmp/ses/z.mp4' -i "${VX[3]/.*/}.mp3" -c copy "${VX[3]/.*/}.${VX[1]}.mkv" 2>&1|tee '/tmp/ses/f1.txt'
      ) >/dev/null &
      ff=$!
      while ps "$ff" >/dev/null; do
       echo -ne "\r$(strings '/tmp/ses/f1.txt'|grep "^frame"|tail -n1|grep -o "size.*speed....")"
       sleep 0.5
       if [[ "$(strings '/tmp/ses/f1.txt'|tail -n1)" =~ "Error" ]]; then
        echo -ne "\r$(strings '/tmp/ses/f1.txt'|tail -n1)";
       fi
      done
      echo -ne "\r\n"
      echo -ne "\r${m_i}${y_K}TAMAMLANDI:${y_x}${r_X} '${VX[3]/.*/}.${VX[1]}.mkv'"
      ;;
      2)
      echo -ne "\r${m_i}${y_K}TAMAMLANDI:${y_x}${r_X} '${VX[3]/.*/}.${VX[1]}.mp3'"
      ;;
     esac
    fi
   fi
  done
  TEMiZLE 2>/dev/null
  ;;
  -m)
  cop() {
  find '/tmp/ses/X' -type f \( \
                    -iname "*.mp3" \
                    -o -iname "bir.txt" \
                    -o -iname "xterm.log" \) -exec rm -rf {} \;
  }
  # X kloser kontrol varsa içi boşaltılır, yoksa oluşturulur.
  if test -d '/tmp/ses/X'; then cop 2>/dev/null; else mkdir -p '/tmp/ses/X'; fi
  # Xterm çalıştırılır bilgi vermek için
  if test -z "$4"; then
   echo "İşlem başlatılıyor..." >'/tmp/ses/X/xterm.log'
   xterm -geometry 80x10-10+350 -fa -hold -T '𝕊𝕌𝔹𝕊𝔼𝕊' -e 'bash -c "watch -n1 cat /tmp/ses/X/xterm.log"' &
   set -- "-m" "$2" "$(xclip -o)" "$(yad --title="𝕊𝕌𝔹𝕊𝔼𝕊" --window-icon="$HOME/.config/subses/subses.png" --file --save).mp3"
  fi
  echo -ne >'/tmp/ses/X/bir.txt'
  al="$(tr '.|?|!|,|:|;' '\n' <<<"$3"|awk NF|sed -e 's/\W/ /g' -e 's/\s\{1,\}/ /g' -e 's/^\s\{1,\}//')"
  X=0
  A="$4"
  i="0"
  D="01234567"
  R="$(grep -c '[A-Za-z]' <<<"$al")"
  echo -e "${m_r}${y_K}༺  ${y_X}${r_X} ${m_i}${y_K}⟆υᑲ⟆∈⟆${r_X}${y_X} ${m_r}${y_K}༻ ${r_X}${y_X}\nSES: ${A}\nDiL: ${2}"
  # İptal olmasına karşın dosyaları silmek için tuzak kuralım.
  trap cop EXIT
  # GOOGLE URL kullanılarak ses dosyalar yapılır.
  while read -r oku; do
   if [[ "$oku" =~ ([A-Za-z]) ]]; then
    (( X++ )) || true
    wget -q -U Mozilla -O "/tmp/ses/X/$X.mp3" \
    "https://translate.google.com/translate_tts?ie=UTF-8&tl=${2}&client=tw-ob&q=${oku,,}" >/dev/null
    echo "file '/tmp/ses/X/$X.mp3' " >>'/tmp/ses/X/bir.txt'
    P="$(grep -c 'mp3' '/tmp/ses/X/bir.txt')"
    Y=$(("${P}*100/${R}*100"/100))
    B=$(("${Y}*5"/10))
    K=$((50-B))
    T=$(perl -E 'say "┃"x'"$B")
    E=$(perl -E 'say "╺"x'"$K")
    # shellcheck disable=SC2027
    j="\e[1;3"${D:i++%${#D}:1}"m"
    echo -ne "\r${y_K}`du -hs '/tmp/ses/X'|cut -f1`${y_X}${j}\
    ╏${r_X}${k_i}${T}${r_X}${m_r}${y_K}${E}${y_X}${r_X}${j}╏${r_X}\e[21;34m${y_K} ${Y}%${y_X}${r_X}"
    pidof xterm >/dev/null && echo "${P}>${W} ╏${T}${E}╏${Y}%" >'/tmp/ses/X/xterm.log'
   fi
  done <<<"$al"

  # Ses dosyalrı indexlenir ve birleştirilir.
  O=(/tmp/ses/X/*.mp3)
  if test "${#O[@]}" -eq "$(grep -c '[A-Za-z]' <<<"$al")"; then
   echo -ne "\r\nSon işlem Başlatıldı: ${A}\n"
   # Birleştirme yapılır başarılı olunduğunda mevcut işlem kloserü boşaltılır.
   ffmpeg -nostdin -loglevel quiet -f concat -safe 0 -i '/tmp/ses/X/bir.txt' -c:a copy "${A}" \
   && echo -ne "\r\n${m_i}${y_K}BİTTİ${y_X}${r_X}\n${y_K}${A}${y_X}\n"\
   || echo -e "\nHatalı işlem.."
   pidof xterm >/dev/null && echo "BİTTİ: ${A}" >'/tmp/ses/X/xterm.log'
  else
   # Hatalı işlem alınırsa yad ile bilgilendirilir.
   pidof xterm >/dev/null && yad --title="𝕊𝕌𝔹𝕊𝔼𝕊" \
                                 --window-icon="$HOME/.config/subses/subses.png" \
                                 --height=10 --width=400 --dnd --text="Hatalı işlem sonu.."
   pidof xterm >/dev/null || echo -e "\r\n${k_i}${y_K}İŞLEM HATASI...! ${y_X}${r_X}"
